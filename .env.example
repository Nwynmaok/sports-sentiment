# ── Social sources (all free) ────────────────────────────────────────
# Reddit: create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_secret

# Bluesky: Settings -> Privacy and Security -> App Passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Optional paid sources ────────────────────────────────────────────
# twitterapi.io (~$0.15/1K tweets) — sharp-account Twitter timelines
TWITTERAPI_IO_KEY=

# SportsGameOdds (free tier) — player props; without it, ESPN provides
# game lines only. https://sportsgameodds.com
SGO_API_KEY=

# ── Delivery (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram channel reading (my.telegram.org -> API development tools),
# then one-time: python3 -m scripts.telegram_login
# (different creds from the BOT_TOKEN above, which is for alert delivery)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# YouTube Data API v3 (Google Cloud Console -> enable API -> create key)
YOUTUBE_API_KEY=

# Threads keyword search — Meta developer app with the Threads use case
# and threads_keyword_search permission (500 searches per rolling 7 days)
THREADS_ACCESS_TOKEN=
