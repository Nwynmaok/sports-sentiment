# ── Social sources (all free) ────────────────────────────────────────
# Reddit: create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_secret

# Bluesky: Settings -> Privacy and Security -> App Passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Optional paid sources ────────────────────────────────────────────
# twitterapi.io (~$0.15/1K tweets) — sharp-account Twitter timelines
TWITTERAPI_IO_KEY=

# SportsGameOdds (free tier) — player props; without it, ESPN provides
# game lines only. https://sportsgameodds.com
SGO_API_KEY=

# ── Delivery (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
